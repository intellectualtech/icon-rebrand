<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_rebrand_custom" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.rebrand.custom</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app name="icon_rebrand" string="Rebrand Icons">
                    <block title="Custom Per-App Icons (Dashboard Tiles)">
                        <setting id="icon_rebrand_apply_icons"
                                 string="Apply Custom Icons"
                                 help="Loads PNG files from static/icons and applies them to root app menus.">
                            <div class="text-muted mb-2">
                                Put your PNG files in static/icons and keep names aligned with mapping in models/config_settings.py.
                            </div>
                            <button name="action_apply_custom_app_icons"
                                    type="object"
                                    string="Apply Custom Icons to Each App"
                                    class="btn btn-primary"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>