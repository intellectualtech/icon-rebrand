<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_icon_rebrand_settings" model="ir.actions.act_window">
        <field name="name">Rebrand Icons</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'icon_rebrand'}</field>
    </record>

    <menuitem id="menu_icon_rebrand_root"
              name="Rebrand Icons"
              parent="base.menu_custom"
              sequence="95"
              action="action_icon_rebrand_settings"
              groups="base.group_system"/>
</odoo>
